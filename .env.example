# Copy this file to .env and fill your values
SARVAM_API_KEY=your_sarvam_api_key_here

# Change this to set voice language
SARVAM_TTS_LANGUAGE=en-IN

# Speaker for bulbul:v3 (example: shubh, ritu, aditya)
SARVAM_TTS_SPEAKER=shubh

# TTS model and speaking pace
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_PACE=1.0

# Ollama settings (for intelligent fallback replies)
OLLAMA_ENABLE=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=30
LOG_OLLAMA_FAILURES=true

# Conversation context settings
CONVERSATION_HISTORY_LIMIT=10
PERSIST_CONVERSATION_HISTORY=false
CONVERSATION_HISTORY_FILE=conversation_history.json

# Weather config
WEATHER_CITY=Patna
